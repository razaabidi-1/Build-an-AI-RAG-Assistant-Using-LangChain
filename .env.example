# HuggingFace credentials  (100% FREE)
# Copy this file to .env and fill in your real token
#
# Get your FREE token in 2 minutes:
#   1. Sign up at https://huggingface.co  (free)
#   2. Go to  https://huggingface.co/settings/tokens
#   3. Click "New token" → Role: Read → copy it here

HUGGINGFACEHUB_API_TOKEN=hf_your_token_here
